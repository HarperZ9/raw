LIBRARY d3d11

EXPORTS
    ; ==========================================================================
    ; ENBSeries v0.492 for GTA V — Export Table (72 exports)
    ; Matches original d3d11.dll export table exactly for full SDK compatibility.
    ; ==========================================================================

    ; === D3D11 Proxy Functions (6) ===
    ; Core functions: ASM trampolines -> real d3d11.dll
    D3D11CoreCreateDevice          = Trampoline_D3D11CoreCreateDevice
    D3D11CoreCreateLayeredDevice   = Trampoline_D3D11CoreCreateLayeredDevice
    D3D11CoreGetLayeredDeviceSize  = Trampoline_D3D11CoreGetLayeredDeviceSize
    D3D11CoreRegisterLayers        = Trampoline_D3D11CoreRegisterLayers
    ; Create functions: our C++ implementations (aliased to avoid dllimport clash)
    D3D11CreateDevice              = ENB_D3D11CreateDevice_Impl
    D3D11CreateDeviceAndSwapChain  = ENB_D3D11CreateDeviceAndSwapChain_Impl

    ; === ENB SDK API (8) ===
    ENBGetSDKVersion
    ENBGetVersion
    ENBGetGameIdentifier
    ENBGetParameter
    ENBSetParameter
    ENBSetCallbackFunction
    ENBGetRenderInfo
    ENBGetState

